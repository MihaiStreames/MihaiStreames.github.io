root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
max_line_length = 100

[*.py]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,toml}]
indent_style = space
indent_size = 2

[*.{svelte,ts,js}]
indent_style = tab
indent_size = 2

[*.css]
indent_style = tab
indent_size = 2

[*.html]
indent_style = tab
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2
